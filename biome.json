{
  "$schema": "https://biomejs.dev/schemas/2.3.0/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/.next",
      "!**/.next/**",
      "!**/.turbo",
      "!**/.turbo/**",
      "!**/dist",
      "!**/dist/**",
      "!**/build",
      "!**/build/**",
      "!**/node_modules",
      "!**/node_modules/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true
  }
}
