{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": ["**/.env", "**/.env.production"],
  "globalEnv": [
    "API_PUBLIC_URL",
    "AUTH_SECRET",
    "AUTH_TRUSTED_ORIGINS",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_TRUSTED_ORIGINS",
    "BETTER_AUTH_URL",
    "CRON_SECRET",
    "DATABASE_URL",
    "IS_LAUNCHED",
    "LEMONSQUEEZY_API_KEY",
    "LEMONSQUEEZY_STORE_ID",
    "LEMONSQUEEZY_WEBHOOK_SECRET",
    "LEMON_SQUEEZY_CHECKOUT_URL",
    "LEMON_SQUEEZY_GROWTH_VARIANT_ID",
    "LEMON_SQUEEZY_PORTAL_URL",
    "LEMON_SQUEEZY_PRO_VARIANT_ID",
    "LEMON_SQUEEZY_STARTER_CHECKOUT_URL",
    "LEMON_SQUEEZY_WEBHOOK_SECRET",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_DASHBOARD_URL",
    "NEXT_PUBLIC_SITE_URL",
    "RESEND_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "generated/**",
        "build/**",
        "lib/**"
      ]
    },
    "clean": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "interactive": true
    },
    "db:generate": {
      "cache": false,
      "outputs": ["generated/**"]
    },
    "db:push": {
      "cache": false,
      "interactive": true
    },
    "db:validate": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:portless": {
      "cache": false,
      "persistent": true
    },
    "format": {},
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    }
  },
  "ui": "tui"
}
