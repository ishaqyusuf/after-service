{
  "name": "@afterservice/jobs",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "deploy": "bun run --filter @afterservice/db db:generate && bun ../../scripts/with-workspace-env.mjs --mode production -- trigger deploy",
    "dev": "bun ../../scripts/with-workspace-env.mjs --mode local -- trigger dev",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@afterservice/db": "workspace:*",
    "@trigger.dev/sdk": "4.0.1"
  },
  "devDependencies": {
    "@afterservice/tsconfig": "workspace:*",
    "@types/node": "^25.2.3",
    "trigger.dev": "4.0.1",
    "typescript": "^5.9.3"
  }
}
