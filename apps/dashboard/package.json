{
  "name": "@afterservice/dashboard",
  "private": true,
  "scripts": {
    "build": "bun ../../scripts/with-workspace-env.mjs --mode production -- next build --turbopack",
    "dev": "bun ../../scripts/with-workspace-env.mjs --mode local -- next dev --turbopack -p 4101",
    "dev:portless": "PORTLESS_APP_PORT=${PORTLESS_APP_PORT:-4101} PORTLESS_WILDCARD=${PORTLESS_WILDCARD:-1} PORTLESS_SYNC_HOSTS=${PORTLESS_SYNC_HOSTS:-0} portless app-afterservice next dev --turbopack",
    "lint": "biome check .",
    "start": "bun ../../scripts/with-workspace-env.mjs --mode production -- next start -p 4101",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@afterservice/api": "workspace:*",
    "@afterservice/auth": "workspace:*",
    "@afterservice/db": "workspace:*",
    "@afterservice/site-nav": "workspace:*",
    "@afterservice/ui": "workspace:*",
    "@afterservice/utils": "workspace:*",
    "next": "^16.2.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@afterservice/tsconfig": "workspace:*",
    "@types/node": "^25.2.3",
    "@types/react": "~19.1.0",
    "@types/react-dom": "^19.1.9",
    "typescript": "^5.9.3"
  }
}
